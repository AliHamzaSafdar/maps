# Template for environment variables. Copy to .env and fill in real values.
#   cp .env.example .env

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True

# Google (Places API New + Gemini)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MAPS_API_KEY=your-google-api-key

# AWS Location Service — usually provided via ~/.aws/credentials instead.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-2

AWS_API_KEY=your-aws-location-api-key-here
AWS_DEFAULT_REGION=us-east-2
